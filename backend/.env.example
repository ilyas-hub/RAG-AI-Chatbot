# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL via Prisma)
METADATA_DB_URL=postgresql://user:password@localhost:5432/chatbot?schema=public

# OpenRouter (LLM + Embeddings)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Pinecone (Vector DB)
PINECONE_API_KEY=pcsk_your-key-here
PINECONE_INDEX_NAME=chatbot

# Redis (Rate Limiting)
REDIS_URL=redis://localhost:6379

# Auth (Logto JWT)
LOGTO_JWKS_URL=https://your-logto-instance.app/.well-known/jwks.json
LOGTO_ISSUER=https://your-logto-instance.app/oidc
LOGTO_RESOURCE_INDICATOR=https://your-api.example.com

# Cloudflare AI Gateway (optional)
# CLOUDFLARE_GATEWAY_BASE_URL=https://gateway.ai.cloudflare.com/v1/account/gateway

# Chatbot defaults (optional)
# CHATBOT_DEFAULT_MODEL=meta-llama/llama-3.1-8b-instruct:free
# CHATBOT_FALLBACK_MODEL=google/gemma-2-9b-it:free
# CHATBOT_EMBEDDING_MODEL=openai/text-embedding-3-small
# CHATBOT_SCORE_THRESHOLD=0.72
# CHATBOT_MAX_CONTEXT_CHUNKS=5
