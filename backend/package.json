{
  "name": "rag-chatbot-backend",
  "version": "1.0.0",
  "description": "RAG AI Chatbot — Express backend with Pinecone, OpenRouter, and Prisma",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json --resolve-full-paths",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"src/**/*.{ts,js,json}\" \"prisma/**/*.prisma\"",
    "clean": "rimraf dist",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema=prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=prisma/schema.prisma",
    "db:seed": "tsx scripts/seed.ts seed",
    "db:unseed": "tsx scripts/seed.ts unseed",
    "seed:chatbot": "tsx scripts/seed.ts seed",
    "ingest:chatbot": "tsx scripts/ingest-chatbot-faqs.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=24.10.0"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.91",
    "@pinecone-database/pinecone": "^4.0.0",
    "@prisma/client": "^6.17.1",
    "ai": "^5.0.137",
    "bullmq": "^5.65.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "jose": "^6.1.0",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "uuid": "^13.0.0",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.7.2",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "prettier": "^3.6.2",
    "prisma": "^6.17.1",
    "rimraf": "^6.1.2",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
